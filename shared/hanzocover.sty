% hanzocover.sty — Monochrome cover page for Hanzo AI papers
% Design: Eames-minimal. Small logo top-left. Clean centered title.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{hanzocover}[2026/04/06 Hanzo Research Cover Page]

\RequirePackage{tikz}
\RequirePackage{xcolor}
\RequirePackage{graphicx}
\RequirePackage[margin=1in]{geometry}

\newcommand{\hanzocoverpage}{%
  \newgeometry{margin=0pt}
  \thispagestyle{empty}
  \begin{tikzpicture}[remember picture,overlay]
    % Black background
    \fill[black] (current page.south west) rectangle (current page.north east);

    % Small H logo — top left corner
    \node[anchor=north west] at ([xshift=1.4cm,yshift=-1.2cm]current page.north west) {%
      \begin{tikzpicture}[scale=0.014,xscale=-1]
        \fill[white] (0,44.6) rectangle (22.2,67);
        \fill[white] (0,0) rectangle (22.2,22.3);
        \fill[white] (44.5,44.6) rectangle (66.7,67);
        \fill[white] (44.5,0) rectangle (66.7,22.3);
        \fill[white] (22.2,22.3) -- (0,44.6) -- (44.5,44.6) -- (66.7,22.3) -- cycle;
      \end{tikzpicture}%
    };

    % Title
    \node[white, font=\fontsize{20}{26}\selectfont\bfseries,
          text width=11cm, align=center]
      at ([yshift=1cm]current page.center)
      {\hyphenpenalty=10000\exhyphenpenalty=10000\@title};

    % Thin rule
    \draw[white!25, line width=0.3pt]
      ([yshift=-0.8cm,xshift=-3.5cm]current page.center) --
      ([yshift=-0.8cm,xshift=3.5cm]current page.center);

    % Author
    \node[white!45, font=\fontsize{8.5}{11}\selectfont]
      at ([yshift=-1.6cm]current page.center)
      {Zach Kelling};

    % Affiliation
    \node[white!30, font=\fontsize{7.5}{10}\selectfont\itshape]
      at ([yshift=-2.3cm]current page.center)
      {Hanzo AI};

    % Date
    \node[white!25, font=\fontsize{7.5}{10}\selectfont]
      at ([yshift=-3cm]current page.center)
      {\@date};

    % Footer
    \node[white!15, font=\fontsize{6}{8}\selectfont, anchor=south west]
      at ([xshift=1.4cm,yshift=1cm]current page.south west)
      {Hanzo AI};

    \node[white!15, font=\fontsize{6}{8}\selectfont, anchor=south east]
      at ([xshift=-1.4cm,yshift=1cm]current page.south east)
      {RESEARCH};
  \end{tikzpicture}
  \restoregeometry
  \newpage
}

\let\luxcoverpage\hanzocoverpage
\let\hanzocover\hanzocoverpage
