% hanzo-defense.sty — Black coversheet, monochrome defense white paper style
% Hanzo Industries / Lux Industries / Zoo Labs Foundation
% 2026

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{hanzo-defense}[2026/01/10 Hanzo Defense White Paper Style]

% ============================================================================
% Core packages
% ============================================================================
\RequirePackage[utf8]{inputenc}
\RequirePackage[T1]{fontenc}
\RequirePackage{amsmath,amssymb,amsthm}
\RequirePackage{graphicx}
\RequirePackage{algorithm}
\RequirePackage{algpseudocode}
\RequirePackage{booktabs}
\RequirePackage{listings}
\RequirePackage{xcolor}
\RequirePackage{tikz}
\RequirePackage{enumitem}
\RequirePackage{caption}
\RequirePackage{subcaption}
\RequirePackage{fancyhdr}
\RequirePackage{tabularx}
\RequirePackage{multirow}
\RequirePackage{float}
\RequirePackage{mathtools}
\RequirePackage[margin=1in,headheight=14.5pt]{geometry}
\RequirePackage[hidelinks]{hyperref}

% ============================================================================
% TikZ libraries
% ============================================================================
\usetikzlibrary{
  arrows.meta,
  positioning,
  shapes.geometric,
  fit,
  calc,
  backgrounds,
  decorations.markings
}

% ============================================================================
% Monochrome palette — no color anywhere
% ============================================================================
\definecolor{black}{RGB}{0,0,0}
\definecolor{white}{RGB}{255,255,255}
\definecolor{darkgray}{RGB}{40,40,40}
\definecolor{medgray}{RGB}{100,100,100}
\definecolor{lightgray}{RGB}{200,200,200}
\definecolor{codebg}{RGB}{245,245,245}
\definecolor{rulegray}{RGB}{80,80,80}

% All hyperlinks invisible (monochrome)
\hypersetup{
  colorlinks=false,
  pdfborder={0 0 0},
  linkcolor=black,
  citecolor=black,
  urlcolor=black
}

% ============================================================================
% Code listings — monochrome
% ============================================================================
\lstset{
  basicstyle=\ttfamily\small,
  breaklines=true,
  frame=single,
  rulecolor=\color{rulegray},
  backgroundcolor=\color{codebg},
  keywordstyle=\bfseries,
  commentstyle=\itshape\color{medgray},
  stringstyle=\color{darkgray},
  numbers=left,
  numberstyle=\tiny\color{medgray},
  numbersep=5pt,
  showstringspaces=false,
  tabsize=2
}

% ============================================================================
% Theorem environments
% ============================================================================
\theoremstyle{plain}
\newtheorem{theorem}{Theorem}[section]
\newtheorem{lemma}[theorem]{Lemma}
\newtheorem{proposition}[theorem]{Proposition}
\newtheorem{corollary}[theorem]{Corollary}

\theoremstyle{definition}
\newtheorem{definition}[theorem]{Definition}
\newtheorem{protocol}[theorem]{Protocol}

\theoremstyle{remark}
\newtheorem{remark}[theorem]{Remark}

% ============================================================================
% Headers and footers
% ============================================================================
\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{\small\textit{\@hanzodoctitle}}
\fancyhead[R]{\small\thepage}
\fancyfoot[C]{\small\textsc{Distribution Statement A: Approved for Public Release}}
\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\footrulewidth}{0.2pt}

% ============================================================================
% Document metadata commands
% ============================================================================
\newcommand{\@hanzodoctitle}{}
\newcommand{\@hanzodocid}{}
\newcommand{\@hanzodocversion}{}
\newcommand{\@hanzodocdate}{}
\newcommand{\@hanzodocclass}{UNCLASSIFIED}
\newcommand{\@hanzodocauthors}{}
\newcommand{\@hanzodocorgs}{}
\newcommand{\@hanzodocabstract}{}

\newcommand{\doctitle}[1]{\renewcommand{\@hanzodoctitle}{#1}}
\newcommand{\docid}[1]{\renewcommand{\@hanzodocid}{#1}}
\newcommand{\docversion}[1]{\renewcommand{\@hanzodocversion}{#1}}
\newcommand{\docdate}[1]{\renewcommand{\@hanzodocdate}{#1}}
\newcommand{\docclass}[1]{\renewcommand{\@hanzodocclass}{#1}}
\newcommand{\docauthors}[1]{\renewcommand{\@hanzodocauthors}{#1}}
\newcommand{\docorgs}[1]{\renewcommand{\@hanzodocorgs}{#1}}
\newcommand{\docabstract}[1]{\renewcommand{\@hanzodocabstract}{#1}}

% ============================================================================
% Black coversheet
% ============================================================================
\newcommand{\makecover}{%
  \thispagestyle{empty}%
  \begin{tikzpicture}[remember picture,overlay]
    % Full black background
    \fill[black] (current page.south west) rectangle (current page.north east);
    %
    % Classification banner — top
    \node[white,font=\small\bfseries\sffamily,anchor=north]
      at ([yshift=-0.6cm]current page.north) {\@hanzodocclass};
    %
    % Top rule
    \draw[white,line width=0.5pt]
      ([yshift=-1.2cm,xshift=2cm]current page.north west) --
      ([yshift=-1.2cm,xshift=-2cm]current page.north east);
    %
    % Document ID — upper right
    \node[white,font=\small\ttfamily,anchor=north east]
      at ([yshift=-1.5cm,xshift=-2cm]current page.north east) {\@hanzodocid};
    %
    % Title block — centered
    \node[white,font=\Huge\bfseries\sffamily,text width=14cm,align=center,anchor=center]
      at ([yshift=2.5cm]current page.center) {\@hanzodoctitle};
    %
    % Subtitle rule
    \draw[white,line width=0.3pt]
      ([yshift=0.8cm,xshift=4cm]current page.center) --
      ([yshift=0.8cm,xshift=-4cm]current page.center);
    %
    % Technical White Paper label
    \node[white,font=\large\sffamily,anchor=center]
      at ([yshift=0.2cm]current page.center) {Technical White Paper};
    %
    % Version and date
    \node[white,font=\normalsize\sffamily,anchor=center]
      at ([yshift=-0.6cm]current page.center) {\@hanzodocversion\quad---\quad\@hanzodocdate};
    %
    % Authors
    \node[white,font=\normalsize\sffamily,anchor=center]
      at ([yshift=-2.2cm]current page.center) {\@hanzodocauthors};
    %
    % Organizations
    \node[lightgray,font=\small\sffamily,text width=12cm,align=center,anchor=center]
      at ([yshift=-3.2cm]current page.center) {\@hanzodocorgs};
    %
    % Bottom rule
    \draw[white,line width=0.5pt]
      ([yshift=2.5cm,xshift=2cm]current page.south west) --
      ([yshift=2.5cm,xshift=-2cm]current page.south east);
    %
    % Distribution statement
    \node[lightgray,font=\footnotesize\sffamily,text width=14cm,align=center,anchor=south]
      at ([yshift=1.2cm]current page.south)
      {Distribution Statement A: Approved for Public Release; Distribution Unlimited.};
    %
    % Classification banner — bottom
    \node[white,font=\small\bfseries\sffamily,anchor=south]
      at ([yshift=0.5cm]current page.south) {\@hanzodocclass};
  \end{tikzpicture}%
  \newpage
}

% ============================================================================
% Section styling — monochrome, clean
% ============================================================================
\renewcommand{\section}{\@startsection{section}{1}{\z@}%
  {-3.5ex \@plus -1ex \@minus -.2ex}%
  {2.3ex \@plus.2ex}%
  {\normalfont\Large\bfseries\sffamily}}
\renewcommand{\subsection}{\@startsection{subsection}{2}{\z@}%
  {-3.25ex\@plus -1ex \@minus -.2ex}%
  {1.5ex \@plus .2ex}%
  {\normalfont\large\bfseries\sffamily}}
\renewcommand{\subsubsection}{\@startsection{subsubsection}{3}{\z@}%
  {-3.25ex\@plus -1ex \@minus -.2ex}%
  {1.5ex \@plus .2ex}%
  {\normalfont\normalsize\bfseries\sffamily}}

% ============================================================================
% Utility commands
% ============================================================================
\newcommand{\fips}[1]{FIPS~#1}
\newcommand{\nist}{NIST}
\newcommand{\pq}{post-quantum}
\newcommand{\PQ}{Post-Quantum}
\newcommand{\eg}{e.g.,\ }
\newcommand{\ie}{i.e.,\ }
\newcommand{\etal}{\textit{et al.}}

\endinput
