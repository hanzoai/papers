% hanzocover.sty — Monochrome cover page for Hanzo AI papers
% Logo: Geometric H mark (from hanzoai/logo)
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{hanzocover}[2026/04/05 Hanzo Research Cover Page]

\RequirePackage{tikz}
\RequirePackage{xcolor}
\RequirePackage{graphicx}
\RequirePackage[margin=1in]{geometry}

\newcommand{\hanzocoverpage}{%
  \newgeometry{margin=0pt}
  \thispagestyle{empty}
  \begin{tikzpicture}[remember picture,overlay]
    \fill[black] (current page.south west) rectangle (current page.north east);

    % Hanzo H logo — geometric block H from hanzoai/logo SVG
    % Two squares top-left and top-right, diagonal bar, two squares bottom
    \begin{scope}[shift={([yshift=4cm]current page.center)}, scale=0.022]
      \fill[white] (0,44.68) rectangle (22.21,67);           % bottom-left square
      \fill[white] (0,0) rectangle (22.21,22.32);            % top-left square
      \fill[white] (44.51,0) rectangle (66.72,22.32);        % top-right square
      \fill[white] (44.51,44.64) rectangle (66.72,67);       % bottom-right square
      % Diagonal bar (the H crossbar)
      \fill[white] (0.09,44.64) -- (22.25,46.83) -- (22.25,44.64) -- cycle;
      \fill[white] (22.25,22.32) -- (66.70,22.32) -- (44.46,44.64) -- (0.09,44.64) -- cycle;
      \fill[white] (44.51,20.08) -- (66.68,22.32) -- (44.51,22.32) -- cycle;
    \end{scope}

    % Title
    \node[white, font=\fontsize{18}{22}\selectfont\bfseries,
          text width=12cm, align=center]
      at ([yshift=1cm]current page.center)
      {\hyphenpenalty=10000\exhyphenpenalty=10000\@title};

    % Rule
    \draw[white!30, line width=0.4pt]
      ([yshift=-0.3cm,xshift=-4cm]current page.center) --
      ([yshift=-0.3cm,xshift=4cm]current page.center);

    % Author
    \node[white!50, font=\fontsize{9}{11}\selectfont]
      at ([yshift=-1.1cm]current page.center) {\@author};

    % Date
    \node[white!30, font=\fontsize{8}{10}\selectfont]
      at ([yshift=-1.9cm]current page.center) {\@date};

    % Footer
    \node[white!20, font=\fontsize{7}{9}\selectfont, anchor=south]
      at ([yshift=0.6cm]current page.south) {Hanzo AI};

    % Classification
    \node[white!20, font=\fontsize{6}{8}\selectfont, anchor=south east]
      at ([xshift=-0.8cm,yshift=0.6cm]current page.south east) {RESEARCH};
  \end{tikzpicture}
  \restoregeometry
  \newpage
}

\let\luxcoverpage\hanzocoverpage
\let\hanzocover\hanzocoverpage
