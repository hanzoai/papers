% hanzocover.sty — Black cover page for Hanzo AI research papers
% Logo: Geometric H — two squares + diagonal slash (from hanzoai/logo)
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{hanzocover}[2024/01/15 Hanzo Research Cover Page]

\RequirePackage{tikz}
\RequirePackage{xcolor}
\RequirePackage{graphicx}
\RequirePackage[margin=1in]{geometry}

\definecolor{hanzoblack}{RGB}{0,0,0}
\definecolor{hanzowhite}{RGB}{255,255,255}
\definecolor{hanzogold}{RGB}{207,181,59}
\definecolor{hanzogray}{RGB}{128,128,128}

\newcommand{\hanzocoverpage}{%
  \newgeometry{margin=0pt}
  \thispagestyle{empty}
  \begin{tikzpicture}[remember picture,overlay]
    \fill[hanzoblack] (current page.south west) rectangle (current page.north east);

    % Hanzo logo — geometric H (two columns of squares + diagonal slash)
    \node at ([yshift=3cm]current page.center) {%
      \begin{tikzpicture}[scale=0.038]
        % Top-left square
        \fill[hanzowhite] (0,44.6) rectangle (22.2,67);
        % Bottom-left square
        \fill[hanzowhite] (0,0) rectangle (22.2,22.3);
        % Top-right square
        \fill[hanzowhite] (44.5,44.6) rectangle (66.7,67);
        % Bottom-right square
        \fill[hanzowhite] (44.5,0) rectangle (66.7,22.3);
        % Diagonal slash (parallelogram)
        \fill[hanzowhite] (22.2,22.3) -- (0,44.6) -- (44.5,44.6) -- (66.7,22.3) -- cycle;
      \end{tikzpicture}%
    };

    \node[hanzowhite, font=\fontsize{28}{34}\selectfont\bfseries\sffamily,
          text width=14cm, align=center]
      at ([yshift=-0.5cm]current page.center) {\@title};

    \node[hanzogray, font=\fontsize{11}{14}\selectfont\sffamily,
          text width=14cm, align=center]
      at ([yshift=-2.5cm]current page.center) {\@author};

    \node[hanzogold, font=\fontsize{10}{12}\selectfont\sffamily]
      at ([yshift=-3.8cm]current page.center) {\@date};

    \fill[hanzogold] ([yshift=0.8cm]current page.south west)
      rectangle ([yshift=0.85cm]current page.south east);

    \node[hanzowhite, font=\fontsize{8}{10}\selectfont\sffamily, anchor=south]
      at ([yshift=0.2cm]current page.south) {%
        Hanzo AI%
      };

    \node[hanzogray, font=\fontsize{7}{9}\selectfont\sffamily, anchor=south east]
      at ([xshift=-1cm,yshift=1.2cm]current page.south east) {RESEARCH};
  \end{tikzpicture}
  \restoregeometry
  \newpage
}

\let\luxcoverpage\hanzocoverpage
\let\hanzocover\hanzocoverpage
